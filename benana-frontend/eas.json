{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://v2.benana.me",
        "EXPO_PUBLIC_API_URL_MOBILE": "https://v2.benana.me",
        "EXPO_PUBLIC_SPOTIFY_CLIENT_ID": "d717b40d2722426ab6cd25525d4ba4fa"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
