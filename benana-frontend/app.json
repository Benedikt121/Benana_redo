{
  "expo": {
    "name": "benana-frontend",
    "slug": "benana-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "benanafrontend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.notbene.benanafrontend",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppleMusicUsageDescription": "Benana uses Apple Music to play and control your music.",
        "NSSupportsLiveActivities": true,
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.notbene.benanafrontend"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-video",
      "expo-sharing",
      "expo-web-browser",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "NowPlayingActivity",
              "displayName": "Now Playing",
              "description": "Shows the currently playing song on the Lock Screen and Dynamic Island",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ],
          "groupId": "group.com.notbene.benanafrontend"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3bc4960f-0845-4f39-8761-72ee6185b7c2"
      }
    },
    "owner": "notbene"
  }
}
